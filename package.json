{
  "name": "@mcptoolshop/claude-guardian",
  "version": "1.2.1",
  "description": "Flight computer for Claude Code — log rotation, watchdog, crash bundles, and MCP self-awareness",
  "type": "module",
  "bin": {
    "claude-guardian": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "verify": "npm test && npm run build && npm pack --dry-run"
  },
  "keywords": [
    "claude",
    "claude-code",
    "guardian",
    "watchdog",
    "mcp",
    "reliability",
    "diagnostics"
  ],
  "author": "mcp-tool-shop",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "archiver": "^7.0.1",
    "commander": "^14.0.3",
    "pidusage": "^4.0.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node": "^25.5.0",
    "@types/pidusage": "^2.0.5",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "HANDBOOK.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mcp-tool-shop-org/claude-guardian.git"
  },
  "homepage": "https://mcp-tool-shop-org.github.io/claude-guardian/",
  "bugs": {
    "url": "https://github.com/mcp-tool-shop-org/claude-guardian/issues"
  }
}
